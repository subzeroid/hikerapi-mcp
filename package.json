{
  "name": "hikerapi-mcp",
  "version": "1.0.2",
  "description": "MCP server for HikerAPI — Instagram data API. Auto-generates tools from the HikerAPI OpenAPI spec.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hikerapi-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"try{require('fs').chmodSync('dist/index.js',0o755)}catch(e){}\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test test/openapi.test.ts test/smoke.test.ts",
    "test:e2e": "node --import tsx --test test/e2e.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "hikerapi",
    "instagram",
    "instagrapi",
    "api",
    "claude",
    "ai",
    "model-context-protocol"
  ],
  "author": "HikerAPI <support@hikerapi.com>",
  "license": "MIT",
  "homepage": "https://hikerapi.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subzeroid/hikerapi-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/subzeroid/hikerapi-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
